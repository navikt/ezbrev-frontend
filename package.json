{
  "name": "ezbrev-frontend-v2",
  "version": "1.0.0",
  "license": "",
  "description": "Ezbrev frontend with react and redux",
  "repository": "",
  "author": "",
  "engines": {
    "node": "16.16.0",
    "npm": "8.11.0"
  },
  "scripts": {
    "start": "set HTTPS=true&&npm-run-all --parallel test:watch server open:src lint:watch",
    "open:src": "webpack-dev-server --config ./webpack.config.js --port 3000 --mode development --open",
    "fullbuild": "npm run build:install && npm run build:webpack",
    "build:install": "npm ci -q",
    "build": "npm run build:webpack",
    "build:webpack": "./node_modules/.bin/webpack",
    "lint": "node_modules/.bin/esw webpack.config.* src tools",
    "lint:watch": "npm run lint -- --watch",
    "test": "mocha --reporter progress tools/testSetup.js \"src/**/*.test.js\"",
    "test:watch": "npm run test -- --watch",
    "server": "json-server --watch db.json --port 8082"
  },
  "dependencies": {
    "@navikt/aksel-icons": "4.7.2",
    "@navikt/ds-css": "4.7.2",
    "@navikt/ds-react": "4.7.2",
    "bootstrap": "5.3.0",
    "buffer": "6.0.3",
    "core-js": "3.31.1",
    "history": "4.7.2",
    "http-server": "0.11.1",
    "popper.js": "^1.12.9",
    "prop-types": "15.6.1",
    "react": "18.2.0",
    "react-bootstrap": "2.8.0",
    "react-copy-to-clipboard": "5.1.0",
    "react-dom": "18.2.0",
    "react-highlight": "0.15.0",
    "react-image-crop": "4.0.1",
    "react-loading": "2.0.3",
    "react-redux": "8.1.1",
    "react-router-dom": "6.14.2",
    "redux": "4.2.1",
    "redux-thunk": "^2.2.0",
    "stream-browserify": "3.0.0",
    "timers-browserify": "2.0.12",
    "toastr": "2.1.4",
    "xml2js": "0.6.0"
  },
  "devDependencies": {
    "@babel/core": "7.22.9",
    "@babel/eslint-parser": "7.22.9",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "7.20.7",
    "@babel/preset-env": "7.22.9",
    "@babel/preset-react": "7.22.5",
    "@babel/register": "7.22.5",
    "@pmmmwh/react-refresh-webpack-plugin": "0.5.10",
    "@redux-devtools/extension": "3.2.5",
    "babel-loader": "9.1.3",
    "cross-env": "^5.1.6",
    "css-loader": "^0.28.11",
    "eslint": "8.45.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-config-react-app": "7.0.1",
    "eslint-plugin-flowtype": "^2.49.3",
    "eslint-plugin-import": "^2.12.0",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-prettier": "5.0.0",
    "eslint-plugin-react": "^7.9.1",
    "eslint-watch": "8.0.0",
    "expect": "23.1.0",
    "file-loader": "6.2.0",
    "jsdom": "8.5.0",
    "json-server": "^0.13.0",
    "mini-css-extract-plugin": "2.7.6",
    "mocha": "10.2.0",
    "npm-run-all": "4.1.3",
    "prettier": "3.0.0",
    "react-refresh": "0.14.0",
    "redux-immutable-state-invariant": "1.2.3",
    "redux-logger": "^3.0.6",
    "style-loader": "^0.21.0",
