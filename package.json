{
  "name": "ezbrev-frontend-v2",
  "version": "1.0.0",
  "license": "",
  "description": "Ezbrev frontend with react and redux",
  "repository": "",
  "author": "",
  "engines": {
    "node": "8.10.0",
    "npm": "5.6.0"
  },
  "scripts": {
    "start": "set HTTPS=true&&npm-run-all --parallel test:watch server open:src lint:watch",
    "open:src": "webpack-dev-server --config ./webpack.config.js --port 3000 --mode development --open",
    "build": "./node_modules/.bin/webpack",
    "lint": "node_modules/.bin/esw webpack.config.* src tools",
    "lint:watch": "npm run lint -- --watch",
    "test": "mocha --reporter progress tools/testSetup.js \"src/**/*.test.js\"",
    "test:watch": "npm run test -- --watch",
    "server": "json-server --watch db.json --port 8082"
  },
  "dependencies": {
    "babel-polyfill": "^6.26.0",
    "bootstrap": "3.3.7",
    "history": "4.7.2",
    "http-server": "0.11.1",
    "popper.js": "^1.12.9",
    "prop-types": "15.6.1",
    "react": "16.4.1",
    "react-bootstrap": "0.32.1",
    "react-copy-to-clipboard": "5.0.1",
    "react-dom": "^16.4.1",
    "react-highlight": "0.12.0",
    "react-image-crop": "4.0.1",
    "react-loading": "2.0.3",
    "react-redux": "^5.0.7",
    "react-router-dom": "^4.2.2",
    "react-router-redux": "^5.0.0-alpha.9",
    "redux": "^3.7.2",
    "redux-thunk": "^2.2.0",
    "toastr": "2.1.4",
    "xml2js": "0.4.19"
  },
  "devDependencies": {
    "babel-core": "^6.26.3",
    "babel-eslint": "^7.2.3",
    "babel-loader": "^7.1.4",
    "babel-plugin-transform-class-properties": "^6.24.1",
    "babel-plugin-transform-object-rest-spread": "^6.26.0",
    "babel-preset-env": "^1.7.0",
    "babel-preset-react": "^6.24.1",
    "babel-register": "6.26.0",
    "cross-env": "^5.1.6",
    "css-loader": "^0.28.11",
    "eslint": "^4.19.1",
    "eslint-config-prettier": "^2.9.0",
    "eslint-config-react-app": "^2.1.0",
    "eslint-plugin-flowtype": "^2.49.3",
    "eslint-plugin-import": "^2.12.0",
    "eslint-plugin-jsx-a11y": "^5.1.1",
    "eslint-plugin-prettier": "^2.6.0",
    "eslint-plugin-react": "^7.9.1",
    "eslint-watch": "3.1.5",
    "expect": "23.1.0",
    "file-loader": "^1.1.11",
    "jsdom": "8.5.0",
    "json-server": "^0.13.0",
    "mini-css-extract-plugin": "^0.4.0",
    "mocha": "5.2.0",
    "npm-run-all": "4.1.3",
    "prettier": "1.13.4",
    "react-hot-loader": "^4.3.3",
    "redux-devtools-extension": "2.13.5",
    "redux-immutable-state-invariant": "1.2.3",
    "redux-logger": "^3.0.6",
    "style-loader": "^0.21.0",
    "webpack": "4.16.0",
    "webpack-cli": "^2.1.4",
    "webpack-dev-server": "^3.1.4"
  },
  "prettier": {
    "singleQuote": true,
    "tabWidth": 4
  }
